#!/bin/sh
# dm-verity initramfs module for Rugix. Runs before the rootfs module
# (85 < 90). Reads the verity geometry + roothash from the kernel
# cmdline (image_types_verity.bbclass formats the hash tree with
# --no-superblock, so there's nothing on-disk to auto-discover from),
# opens the dm-verity device, and redirects bootparam_root to it.

verity_enabled() {
    [ -n "$bootparam_roothash" ] && return 0 || return 1
}

verity_run() {
    if [ "$(echo ${bootparam_root} | cut -c1-9)" = "PARTUUID=" ]; then
        partuuid=$(echo $bootparam_root | cut -c10-)
        root_dev="/dev/disk/by-partuuid/$partuuid"
    else
        root_dev="$bootparam_root"
    fi

    C=0
    while [ ! -e "$root_dev" ] && [ $C -lt 10 ]; do
        debug "Verity: waiting for $root_dev..."
        sleep 1
        C=$(( C + 1 ))
    done
    [ -e "$root_dev" ] || fatal "Verity: root device $root_dev not found"

    msg "Verity: opening $root_dev with hash-offset=$bootparam_roothashoffset"
    veritysetup open \
        --no-superblock \
        --data-block-size="$bootparam_rootblocksize" \
        --hash-block-size="$bootparam_rootblocksize" \
        --data-blocks="$bootparam_rootdatablocks" \
        --hash-offset="$bootparam_roothashoffset" \
        --salt="$bootparam_rootsalt" \
        "$root_dev" rootverity "$root_dev" "$bootparam_roothash" \
        || fatal "Verity: veritysetup open failed"

    bootparam_root="/dev/mapper/rootverity"
}
