#!/usr/bin/env bash
#
# Run the QEMU x86-64 Rugix image with GRUB EFI boot.
#
# Creates a qcow2 overlay on top of the built WIC image, expanded to 16 GiB
# so the Rugix bootstrapping process can create the required A/B system and
# data partitions on first boot.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

BUILD_DIR="${KAS_BUILD_DIR:-${ROOT_DIR}/build}"
DEPLOY_DIR="${BUILD_DIR}/tmp/deploy/images/qemux86-64"

WIC_IMAGE="${DEPLOY_DIR}/core-image-minimal-qemux86-64.rootfs.wic"
OVMF_CODE="${DEPLOY_DIR}/ovmf.code.qcow2"
OVMF_VARS="${DEPLOY_DIR}/ovmf.vars.qcow2"
OVERLAY="${DEPLOY_DIR}/core-image-minimal-qemux86-64.overlay.qcow2"

# Disk size must be large enough for the full partition layout defined in
# bootstrapping.toml: EFI (64 MiB) + system-a (4 GiB) + system-b (4 GiB)
# + data (remaining).
DISK_SIZE="16G"

if [ ! -f "${WIC_IMAGE}" ]; then
    echo "Error: WIC image not found at ${WIC_IMAGE}" >&2
    echo "Build it first with: just build examples/qemu-x86_64-grub.yaml" >&2
    exit 1
fi

if [ ! -f "${OVMF_CODE}" ]; then
    echo "Error: OVMF firmware not found at ${OVMF_CODE}" >&2
    exit 1
fi

# Create a fresh qcow2 overlay backed by the WIC image, expanded to the
# required disk size for bootstrapping.
echo "Creating qcow2 overlay (${DISK_SIZE}) over WIC image..."
qemu-img create -f qcow2 -b "${WIC_IMAGE}" -F raw "${OVERLAY}" "${DISK_SIZE}"

# Copy OVMF vars so the VM gets its own writable EFI variable store.
OVMF_VARS_VM="${DEPLOY_DIR}/ovmf.vars.vm.qcow2"
cp "${OVMF_VARS}" "${OVMF_VARS_VM}"

# Enable KVM acceleration if available.
KVM_ARGS=()
if [ -w /dev/kvm ]; then
    echo "KVM available, enabling hardware acceleration."
    KVM_ARGS+=(-enable-kvm -cpu host)
else
    echo "KVM not available, using software emulation."
fi

echo "Starting QEMU..."
exec qemu-system-x86_64 \
    -machine q35 \
    "${KVM_ARGS[@]}" \
    -m 1024 \
    -smp 4 \
    -drive if=pflash,format=qcow2,readonly=on,file="${OVMF_CODE}" \
    -drive if=pflash,format=qcow2,file="${OVMF_VARS_VM}" \
    -drive format=qcow2,file="${OVERLAY}" \
    -serial mon:stdio \
    -nographic \
    -nic user,model=virtio-net-pci,hostfwd=tcp::2222-:22 \
    "$@"
